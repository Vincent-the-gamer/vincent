{
  "name": "vincent",
  "type": "module",
  "version": "1.2.1",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "cross-env NODE_ENV=production vite-ssg build && tsx ./scripts/copy-fonts.ts && tsx ./scripts/rss.ts && pnpm run copy-files",
    "spa-build": "cross-env NODE_ENV=production vite build && tsx ./scripts/copy-fonts.ts && tsx ./scripts/rss.ts && pnpm run copy-files",
    "copy-files": "cp _dist_redirects dist/_redirects",
    "dev": "vite --open",
    "preview": "vite preview",
    "redirects": "tsx scripts/redirects.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dep": "taze major -I",
    "tsx": "tsx"
  },
  "dependencies": {
    "@lucky-canvas/vue": "^0.1.11",
    "@snackbar/core": "^1.7.0",
    "@vueuse/core": "^14.2.1",
    "aplayer": "^1.10.1",
    "busuanzi.pure.js": "^1.0.3",
    "dayjs": "^1.11.20",
    "floating-vue": "^5.2.2",
    "nprogress": "^0.2.0",
    "pixi.js": "^8.18.1",
    "sharp": "^0.34.5",
    "simplex-noise": "^4.0.3",
    "typed.js": "^3.0.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vue-router-better-scroller": "^0.0.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@iconify/json": "^2.2.464",
    "@octokit/rest": "^22.0.1",
    "@shikijs/markdown-it": "^4.0.2",
    "@shikijs/transformers": "^4.0.2",
    "@shikijs/twoslash": "^4.0.2",
    "@types/diacritics": "^1.3.3",
    "@types/fs-extra": "^11.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/markdown-it-link-attributes": "^3.0.5",
    "@types/nprogress": "^0.2.3",
    "@unhead/vue": "^3.0.4",
    "@unocss/preset-web-fonts": "66.3.2",
    "@unocss/reset": "^66.6.8",
    "@vitejs/plugin-vue": "^6.0.6",
    "cross-env": "^10.1.0",
    "diacritics": "^1.3.0",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "fast-glob": "^3.3.3",
    "feed": "^5.2.1",
    "fs-extra": "^11.3.4",
    "gray-matter": "^4.0.3",
    "lint-staged": "^16.4.0",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-github-alerts": "^1.0.1",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-table-of-contents": "^1.2.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "shiki": "^4.0.2",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.11.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "unocss": "^66.6.8",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.0.0",
    "unplugin-vue-markdown": "^30.0.0",
    "unplugin-vue-router": "^0.19.2",
    "vite": "^8.0.9",
    "vite-plugin-inspect": "^11.3.3",
    "vite-plugin-optimize-exclude": "^0.0.1",
    "vite-plugin-pages": "^0.33.3",
    "vite-ssg": "^28.3.0",
    "vite-svg-loader": "^5.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "vue-demi"
    ],
    "ignoredBuiltDependencies": [
      "simple-git-hooks",
      "unrs-resolver"
    ]
  },
  "resolutions": {
    "vite": "^8.0.9"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
